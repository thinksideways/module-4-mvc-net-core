@{
    Layout = "_Layout";
}

@using Northwind.Models
@model IEnumerable<Category>

<div class="container">

    <div class="row mt-4 mb-2">
        <div class="col-md-12 col-sm-12">
            <ul class="list-group">
                @foreach (Category category in Model)
                {
                    <li class="list-group-item">
                        <a href="@Url.Action("Index", "Product", new {id = category.CategoryId})">@category.CategoryName - @category.Description</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>
