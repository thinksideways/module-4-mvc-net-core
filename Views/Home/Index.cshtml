@{
    Layout = "_Layout";
}

@model IEnumerable<Discount>

<div class="container-fluid">
    <div class="row mb-2">
        <div class="col-md-12 col-sm-12">
            <div class="p-4 m-2 mt-4 rounded-1 border border-secondary-subtle h-100">
                <h1>Northwind Traders</h1>
                <p>
                We have the worst prices and selection of low quality foods &amp;
                processed beverages on the planet! Check out our featured opposite-day discounts!
                </p>
                <p>
                For the least exceptional international cuisine, look no further.  For the best look much farther.
                </p>
                <hr class="my-4">
                <a class="btn btn btn-outline-success btn-lg" href="#" role="button"><i class="bi bi-bag"></i> Order Now</a>
            </div>
        </div>
    </div>
    <div class="p-2 m-2 row row-cols-1 row-cols-lg-3 featured" id="discount-row">
        @foreach (Discount d in Model)
        {
            <div class="col-md-4 col-sm-12 discounts px-2 py-4">
                    <div class="p-4 m-2 mt-4 rounded-1 border border-secondary-subtle">
                    <h4>@d.Title</h4>
                    <div class="mb-4">
                        @d.Description
                    </div>
                    <i>Discount expires: @d.EndTime.ToString("MM/dd/yyyy")</i><br />
                    <a href="#" data-code="@d.Code" data-title="@d.Title" data-product="@d.Product.ProductName" class="discount"><i class="far fa-hand-point-right"></i> Discount Code</a>
                </div>      
            </div>
        }
    </div>
        <!-- toast -->
        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header">
                    <strong class="me-auto" id="product">Product</strong>
                    <small class="text-body-secondary" id="title">just now</small>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    Discount Code: <span id="code">Code</span>
                </div>
            </div>
        </div>
</div>